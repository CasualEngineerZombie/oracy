FROM node:20-alpine

# Install Bun for fast package management
RUN npm install -g bun

# Set working directory
WORKDIR /app

# Copy dependency files
COPY package.json ./
COPY bun.lock* ./

# Install dependencies
RUN bun install --frozen-lockfile

# Copy application code
COPY . .

# Expose port
EXPOSE 5173

# Default command
CMD ["bun", "run", "dev", "--host"]
